# Django Settings
SECRET_KEY=tu-secret-key-super-segura-aqui

# Producción: DEBUG=False (valor por defecto si no se define la variable)
# Desarrollo local: cambiar a DEBUG=True en tu .env personal
DEBUG=False

ALLOWED_HOSTS=tu-dominio.com,www.tu-dominio.com

# Database (Railway/Heroku provee DATABASE_URL automáticamente)
# DATABASE_URL=postgres://user:password@host:5432/database

# Redis (opcional, para cache)
# REDIS_URL=redis://host:6379/0

# Email (SMTP para envío de backups y alertas)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-password-de-app

# Backup: destinatario del backup diario automático
# Cada instancia/cliente debe tener su propio valor
# BACKUP_EMAIL_RECIPIENT=destinatario@gmail.com

# Sentry (monitoreo de errores, opcional)
# SENTRY_DSN=https://tu-sentry-dsn-aqui
